# Copy to .env for a production (VPS) deploy:  cp .env.example .env
#
# SITE_ADDRESS — the public address Caddy serves QuickRx on and obtains an
# HTTPS certificate for. Two options:
#   1. A domain you own, with a DNS A record pointing at this server:
#        SITE_ADDRESS=quickrx.example.com
#   2. No domain? Use sslip.io, which resolves <ip>.sslip.io to that IP, so you
#      get real HTTPS on a bare server IP with nothing to buy:
#        SITE_ADDRESS=203.0.113.10.sslip.io   (replace with your server's IP)
#
# Do NOT include http://, https://, or a port number.
SITE_ADDRESS=your-domain-or-<server-ip>.sslip.io
